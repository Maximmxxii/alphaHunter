# AlphaHunter — Variables de entorno
# Copiar a .env y completar los valores

# ── Alpaca Paper Trading ────────────────────────────────────────────────────
# Obtener en: https://app.alpaca.markets → Paper Account → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL base de Alpaca (paper o live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Para cuenta live:
# ALPACA_BASE_URL=https://api.alpaca.markets

# ── Auth — JWT ──────────────────────────────────────────────────────────────
# Cambiar por un secret aleatorio y largo en producción
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=alphahunter-dev-secret-change-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. localhost:8081 and localhost:19006
# are always allowed (hardcoded). Add your production domain here.
ALLOWED_ORIGINS=https://api.actualtrends.blog

# ── Encryption — Fernet key (SEPARATE from JWT_SECRET) ─────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER reuse JWT_SECRET here. Rotating JWT_SECRET must not break stored encrypted keys.
ENCRYPTION_KEY=

# ── Auth — Google OAuth ─────────────────────────────────────────────────────
# Pasos para obtenerlo:
# 1. Ir a https://console.cloud.google.com
# 2. Crear/seleccionar un proyecto
# 3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 4. Tipo: Web application
# 5. Agregar redirect URI: https://auth.expo.io/@tu-usuario/alphahunter
# 6. Copiar el "Client ID" aquí
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Frontend — Expo ─────────────────────────────────────────────────────────
# El GOOGLE_CLIENT_ID también debe estar disponible en el frontend:
# En frontend/.env: EXPO_PUBLIC_GOOGLE_CLIENT_ID=<mismo valor>
